# Template for Tourist Companion environment settings.
# Copy to .env and adjust for your machine:  cp .env.example .env
# The .env file is gitignored; this template is committed.

# Runtime environment: development | production
TC_ENV=development

# --- Sessions ---
TC_SESSION_COOKIE=tc_session
TC_SESSION_DAYS=30
# HTTPS-only cookies. false for local http; auto-true when TC_ENV=production.
TC_COOKIE_SECURE=false

# --- Server ---
PORT=8000

# --- Database ---
# TC_DB_PATH=data/app.db
