# Template for Tourist Companion environment settings.
# Copy to .env and adjust for your machine:  cp .env.example .env
# The .env file is gitignored; this template is committed.

# Runtime environment: development | production
TC_ENV=development

# --- Sessions ---
TC_SESSION_COOKIE=tc_session
TC_SESSION_DAYS=30
# HTTPS-only cookies. false for local http; auto-true when TC_ENV=production.
TC_COOKIE_SECURE=false

# --- Server ---
PORT=8000

# --- Database ---
# SQLite file used when DATABASE_URL is not set (local dev / tests).
# TC_DB_PATH=data/app.db

# Postgres connection string. Railway injects this automatically when a
# Postgres service is attached — leave unset locally to keep using SQLite.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Redis for rate limiting + rates cache. Railway injects this when a Redis
# service is attached — leave unset locally for the in-memory fallback.
# REDIS_URL=redis://host:6379

# --- Admin ---
# Comma-separated emails auto-promoted to admin on login/register.
# TC_ADMIN_EMAILS=you@example.com

# --- Google Maps (optional) ---
# Browser key for the interactive trip map (Maps JavaScript API). Ships to the
# client, so restrict it by HTTP referrer in the Google Cloud console. Leave
# blank to disable the map — the rest of the app works without it.
TC_MAPS_KEY=
